# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development                          # development | staging | production
APP_SECRET_KEY=change-this-to-random-64-char-secret
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aeaop
POSTGRES_USER=aeaop
POSTGRES_PASSWORD=aeaop_secret_change_me
DATABASE_URL=postgresql+asyncpg://aeaop:aeaop_secret_change_me@localhost:5432/aeaop
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_SESSION_DB=1
REDIS_CACHE_DB=2

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_PREFIX=aeaop

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=aeaop-platform

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=miniosecret
MINIO_SECURE=false
MINIO_BUCKET_CONFIGS=aeaop-configs
MINIO_BUCKET_REPORTS=aeaop-reports
MINIO_BUCKET_SNAPSHOTS=aeaop-snapshots
MINIO_BUCKET_AUDIT=aeaop-audit

# ── HashiCorp Vault ───────────────────────────────────────────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token
VAULT_MOUNT_KV=secret
VAULT_ROLE=aeaop-platform

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=aeaop
KEYCLOAK_CLIENT_ID=aeaop-backend
KEYCLOAK_CLIENT_SECRET=change-this-keycloak-secret

# ── AI / LLM ──────────────────────────────────────────────────────────────────
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=no-key-required
OLLAMA_BASE_URL=http://localhost:11434

# Primary reasoning model
LLM_PRIMARY_MODEL=qwen3:72b
LLM_FAST_MODEL=qwen3:14b
LLM_CODE_MODEL=qwen2.5-coder:32b
LLM_VISION_MODEL=qwen2.5vl:72b
LLM_EMBEDDING_MODEL=nomic-embed-text:v2

# AI behavior
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=120

# ── SNMP ──────────────────────────────────────────────────────────────────────
SNMP_COMMUNITY=public
SNMP_VERSION=2c
SNMP_TIMEOUT=5
SNMP_RETRIES=3
SNMP_POLL_INTERVAL_SECONDS=300      # 5 minutes

# ── Services (internal) ───────────────────────────────────────────────────────
NOC_SERVICE_PORT=8001
SOC_SERVICE_PORT=8002
SERVER_SERVICE_PORT=8003
PHYSEC_SERVICE_PORT=8004
RAG_SERVICE_PORT=8005
AI_SERVICE_PORT=8006
CONFIG_SERVICE_PORT=8007
REPORT_SERVICE_PORT=8008
AUTH_SERVICE_PORT=8009
ALERT_SERVICE_PORT=8010
DISCOVERY_SERVICE_PORT=8011
AUDIT_SERVICE_PORT=8012
HEALING_SERVICE_PORT=8013

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Autonomy Settings ─────────────────────────────────────────────────────────
AUTO_HEAL_ENABLED=true
AUTO_HEAL_MAX_RISK_LEVEL=low           # low | medium | high
REQUIRE_APPROVAL_ABOVE=low             # Risk level requiring human approval
